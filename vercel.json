{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": false,
  "rewrites": [
    { "source": "/英语一", "destination": "/英语一/index.html" },
    { "source": "/英语一/mobile", "destination": "/英语一/mobile/index.html" },
    { "source": "/math", "destination": "/数学一/index.html" },
    { "source": "/cs408", "destination": "/408/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}